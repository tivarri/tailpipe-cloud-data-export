{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PreFlightChecks",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "iam:ListRoles",
        "iam:ListPolicies",
        "s3:ListAllMyBuckets",
        "s3:GetBucketLocation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3BucketManagement",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:PutBucketPolicy",
        "s3:DeleteBucket"
      ],
      "Resource": "arn:aws:s3:::tailpipe-dataexport-*"
    },
    {
      "Sid": "S3ObjectManagement",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::tailpipe-dataexport-*/*"
    },
    {
      "Sid": "CostExportManagement",
      "Effect": "Allow",
      "Action": [
        "bcm-data-exports:ListExports",
        "bcm-data-exports:CreateExport",
        "bcm-data-exports:DeleteExport"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ConnectorRoleManagement",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:CreateRole",
        "iam:PutRolePolicy",
        "iam:ListRolePolicies",
        "iam:DeleteRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:DetachRolePolicy",
        "iam:DeleteRole"
      ],
      "Resource": "arn:aws:iam::${aws:PrincipalAccount}:role/tailpipe-connector-role"
    }
  ]
}
